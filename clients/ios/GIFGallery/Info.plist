<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Only standard HTTPS is used; declaring it here answers the export
         compliance question so TestFlight builds don't stall on "Missing
         Compliance" after every upload. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
</dict>
</plist>
